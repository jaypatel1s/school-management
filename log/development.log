                %p
                  Already have an account.
                  %a.fw-medium.text-primary.text-decoration-none{href: "login"} Log In
                = link_to '/signin', class: "fw-medium text-primary text-decoration-none" do
                  %i.ri-login-box-line.fs-18.position-relative.top-2
                  %span.ms-1 Login

