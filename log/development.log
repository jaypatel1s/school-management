#contact.contact-us-area.pt-150.position-relative.z-2
  .container
    .row.align-items-center
      .col-lg-6
        .contact-us-img.mb-4.mb-lg-0
          = image_tag('landing/contact-us.jpg', alt: 'contact')
      .col-lg-6
        .contact-us-form.ms-xl-4
          %span.top-title
            %span Contact Us
          %h2 Introducing Our Exceptional Team. Meet the Minds Driving Our Success
          %form
            .form-group.mb-4
              %label.label.text-secondary Full Name
              %input.form-control.bg-transparent.h-55{placeholder: "Your full name", type: "text"}
              .form-group.mb-4
                %label.label.text-secondary Email Address
                %input.form-control.bg-transparent.h-55{placeholder: "Your email address", type: "email"}
                .form-group.mb-4
                  %label.label.text-secondary Phone Number
                  %input.form-control.bg-transparent.h-55{placeholder: "Your phone number", type: "text"}
                  .form-group.mb-4
                    %label.label.text-secondary Subject
                    %select.form-select.form-control.bg-transparent.h-55{"aria-label" => "Default select example"}
                      %option Select your subject
                      %option{value: "1"} Help Dask
                      %option{value: "2"} LMS
                      %option{value: "3"} CRM
                  .form-group.mb-4
                    %label.label.text-secondary Phone Number
                    %textarea.form-control.bg-transparent{placeholder: "Write your message...", rows: "5"}
                  .form-group.mb-0
                    %button.btn.btn-primary.py-2.px-4.w-100{type: "submit"}
                      %i.ri-refresh-line.fs-18.text-white.position-relative.top-1.me-1
                      %span Send
      #admin.unlock-area.ptb-150.position-relative.z-1
        .container
          .border-bottom.pb-150
            .row
              .unlock-content
                %h2 Unlock a world of possibilities with Trezo Dashboard.
                %p Experience the difference with Trezo Dashboard. Sign up for a free trial today and see how our intuitive platform can revolutionize your data analysis process.
                %a.btn.btn-primary-div.py-2.px-4.fs-16.fw-medium.rounded-3.text-white{href: "pricing-plan.html"}
                  %i.ri-user-line.fs-18
                  %span.ms-1 Get started - It is free
        = image_tag('landing/shape-1.png', alt: 'shape', class: shape shape-5)
        = image_tag('landing/shape-2.png', alt: 'shape', class: shape shape-6)
      .footers-area.pb-125.position-relative.z-2
        .container
          .row
            .col-lg-3.col-sm-6
              .footer-single-item.mb-4
                %a.footer-logo.d-inline-block.mb-4{href: "#"}
                  = image_tag('logo.svg', alt: 'logo')
                %p.mb-4.pb-lg-2 With customizable dashboards tailored to your needs, collaborate effortlessly with your team and stay ahead with real-time updates.
                %ul.ps-0.mb-0.list-unstyled.d-flex.flex-wrap.gap-3
                  %li
                    %a.text-decoration-none.fs-20.text-primary{href: "https://www.facebook.com/", target: "_blank"}
                      %i.ri-facebook-fill
                  %li
                    %a.text-decoration-none.fs-20.text-primary{href: "https://www.twitter.com/", target: "_blank"}
                      %i.ri-twitter-x-line
                  %li
                    %a.text-decoration-none.fs-20.text-primary{href: "https://www.linkedin.com/", target: "_blank"}
                      %i.ri-linkedin-fill
                  %li
                    %a.text-decoration-none.fs-20.text-primary{href: "https://www.dribbble.com/", target: "_blank"}
                      %i.ri-dribbble-line
            .col-lg-3.col-sm-6
              .footer-single-item.mb-4.ms-lg-5.ps-lg-5
                %h3.mb-md-4.mb-3.fw-semibold Our Products
                %ul.ps-0.mb-0.list-unstyled
                  %li.mb-2.pb-1
                    %a.text-decoration-none{href: "#"} Trezo Dashboard
                  %li.mb-2.pb-1
                    %a.text-decoration-none{href: "#"} Tagus Admin
                  %li.mb-2.pb-1
                    %a.text-decoration-none{href: "#"} eCademy LMS
                  %li.mb-0
                    %a.text-decoration-none{href: "#"} Admash Template
            .col-lg-3.col-sm-6
              .footer-single-item.mb-4.ms-lg-5.ps-lg-4
                %h3.mb-md-4.mb-3.fw-semibold Quick Links
                %ul.ps-0.mb-0.list-unstyled
                  %li.mb-2.pb-1
                    %a.text-decoration-none{href: "#"} Home
                  %li.mb-2.pb-1
                    %a.text-decoration-none{href: "#"} Features
                  %li.mb-2.pb-1
                    %a.text-decoration-none{href: "#"} Testimonials
                  %li.mb-0
                    %a.text-decoration-none{href: "#"} Our Team
            .col-lg-3.col-sm-6
              .footer-single-item.mb-4
                %h3.mb-md-4.mb-3.fw-semibold Privacy Policy
                %ul.ps-0.mb-0.list-unstyled
                  %li.mb-2.pb-1
                    %a.text-decoration-none{href: "#"} Terms  Conditions
                  %li.mb-2.pb-1
                    %a.text-decoration-none{href: "#"} Cookie Policy
                  %li.mb-2.pb-1
                    %a.text-decoration-none{href: "#"} Notice at Collection
                  %li.mb-0
                    %a.text-decoration-none{href: "#"} Privacy Policy
      .copyright-area.bg-white.text-center.py-4
        .container
          %p.fs-14
            \&#xA9;
            %span.text-primary-div Trezo
            is Proudly Owned by
            %a.text-decoration-none.text-primary{href: "https://envytheme.com/", target: "_blank"} EnvyTheme
      %button#backtotop{type: "button"}
        %i.ri-arrow-up-s-line

